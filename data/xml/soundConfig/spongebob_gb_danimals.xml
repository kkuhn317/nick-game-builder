<?xml version="1.0" encoding="utf-8"?>
<soundlist>
	<!-- Player -->
	<sound id="sndPlayerJump" 				volume="1" loop="1" classname="character_jump" />
	<sound id="sndPlayerDoubleJump" 		volume="1" loop="1" classname="character_doubleJump" />
	<sound id="sndPlayerStomp" 				volume="1" loop="1" classname="clamShellHit" />
